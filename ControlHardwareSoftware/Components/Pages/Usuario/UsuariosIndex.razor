@page "/usuarios"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IUsuarioService UsuarioService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Usuarios</h1>
    <button class="btn btn-primary" @onclick="CrearNuevo">
        <i class="bi bi-person-plus"></i> Nuevo Usuario
    </button>
</div>

@* Barra de búsqueda mejorada con icono *@
<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white">Buscar</span>
            <input type="text" class="form-control" placeholder="Buscar por nombre o departamento..."
                   @bind="textoBusqueda" @bind:event="oninput" />
        </div>
    </div>
</div>

@if (usuarios == null)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2">Cargando usuarios...</p>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cargo</th>
                    <th>Departamento</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in UsuariosPaginados)
                {
                    <tr>
                        <td class="fw-bold">@user.nombre</td>
                        <td>@user.cargo</td>
                        <td>@user.departamento</td>
                        <td>@user.correo</td>
                        <td>@user.telefono</td>
                        <td class="text-center">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => Editar(user.id_usuario)" title="Editar">
                                    Editar
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(user.id_usuario)" title="Eliminar">
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Paginación con números de página *@
    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="text-muted">Página @paginaActual de @totalPaginas (@usuariosFiltrados.Count registros)</span>
        <nav>
            <ul class="pagination mb-0 shadow-sm">
                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)">Anterior</button>
                </li>
                
                @for (int i = 1; i <= totalPaginas; i++)
                {
                    int j = i;
                    <li class="page-item @(paginaActual == j ? "active" : "")">
                        <button class="page-link" @onclick="() => CambiarPagina(j)">@j</button>
                    </li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)">Siguiente</button>
                </li>
            </ul>
        </nav>
    </div>
}

@code {
    private List<Usuario>? usuarios;
    private List<Usuario> usuariosFiltrados = new();
    private string _textoBusqueda = "";

    private string textoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                paginaActual = 1;
                FiltrarUsuarios();
            }
        }
    }

    private int paginaActual = 1;
    private int elementosPorPagina = 8; // Ajustado para que quepa mejor en pantalla

    protected override async Task OnInitializedAsync()
    {
        usuarios = await UsuarioService.ObtenerUsuarios();
        usuariosFiltrados = usuarios ?? new();
    }

    private void FiltrarUsuarios()
    {
        if (usuarios == null) return;

        if (string.IsNullOrWhiteSpace(_textoBusqueda))
        {
            usuariosFiltrados = usuarios;
        }
        else
        {
            usuariosFiltrados = usuarios.Where(u =>
                (u.nombre?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.departamento?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private IEnumerable<Usuario> UsuariosPaginados =>
        usuariosFiltrados
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int totalPaginas => Math.Max(1, (int)Math.Ceiling((double)usuariosFiltrados.Count / elementosPorPagina));

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void CrearNuevo() => NavigationManager.NavigateTo("/usuarios/nuevo");
    private void Editar(int id) => NavigationManager.NavigateTo($"/usuarios/editar/{id}");

    private async Task Eliminar(int id)
    {
        // En un proyecto real, aquí llamarías a un modal de confirmación JS
        await UsuarioService.EliminarUsuario(id);
        usuarios = await UsuarioService.ObtenerUsuarios();
        FiltrarUsuarios();
    }
}


@page "/equipos/nuevo"
@page "/equipos/editar/{Id:int}"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IEquipoService EquipoService
@inject IUsuarioService UsuarioService
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@titulo Equipo</PageTitle>

<h3>@titulo Equipo de Cómputo</h3>

<div class="card p-4 shadow-sm">
    <EditForm Model="equipo" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Código Inventario</label>
                <InputText @bind-Value="equipo.codigo_inventario" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Tipo de Equipo</label>
                <InputSelect @bind-Value="equipo.tipo_equipo" class="form-select">
                    <option value="">Seleccione...</option>
                    <option value="Laptop">Laptop</option>
                    <option value="Desktop">Desktop</option>
                    <option value="Servidor">Servidor</option>
                    <option value="Impresora">Impresora</option>
                </InputSelect>
            </div>
            <div class="col-md-4">
                <label class="form-label">Estado</label>
                <InputSelect @bind-Value="equipo.estado" class="form-select">
                    <option value="Activo">Activo</option>
                    <option value="Mantenimiento">Mantenimiento</option>
                    <option value="Baja">Baja</option>
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Marca</label>
                <InputText @bind-Value="equipo.marca" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Modelo</label>
                <InputText @bind-Value="equipo.modelo" class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Número de Serie</label>
                <InputText @bind-Value="equipo.numero_serie" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Fecha de Compra</label>
                <InputDate @bind-Value="equipo.fecha_compra" class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Usuario Responsable</label>
                <InputSelect @bind-Value="equipo.id_usuario" class="form-select">
                    <option value="">-- Sin asignar --</option>
                    @foreach (var user in usuarios)
                    {
                        @* Asegúrate que el modelo Usuario use id_usuario o idusuario según tu SQL *@
                        <option value="@user.id_usuario">@user.nombre</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Ubicación / Área</label>
                <InputSelect @bind-Value="equipo.id_ubicacion" class="form-select">
                    <option value="">-- Sin ubicación --</option>
                    @foreach (var area in ubicaciones)
                    {
                        <option value="@area.id_ubicacion">@area.nombre_area</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success">Guardar Equipo</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private Equipo equipo = new() { estado = "Activo" };
    private List<Usuario> usuarios = new();
    private List<Ubicacion> ubicaciones = new();
    private string titulo = "Nuevo";

    protected override async Task OnInitializedAsync()
    {
        usuarios = await UsuarioService.ObtenerUsuarios();
        ubicaciones = await UbicacionService.ObtenerUbicaciones();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            var equipoDb = await EquipoService.ObtenerEquipoPorId(Id.Value);
            if (equipoDb != null)
            {
                equipo = equipoDb;
                titulo = "Editar";
            }
        }
    }

    private async Task Guardar()
    {
        await EquipoService.GuardarEquipo(equipo);
        NavigationManager.NavigateTo("/equipos");
    }

    private void Cancelar() => NavigationManager.NavigateTo("/equipos");
}

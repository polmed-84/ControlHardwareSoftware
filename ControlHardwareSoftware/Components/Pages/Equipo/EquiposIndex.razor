@page "/equipos"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IEquipoService EquipoService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Inventario de Equipos</PageTitle>

@* Banner Informativo *@
<div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
    <div class="d-flex align-items-center">
        <i class="bi bi-info-circle-fill me-3 fs-4"></i>
        <div>
            <strong>¡Tip de navegación!</strong> Para gestionar los
            <span class="badge bg-info text-dark">Componentes</span>,
            <span class="badge bg-info text-dark">Software instalado</span> y
            <span class="badge bg-info text-dark">Historial de Mantenimiento</span>,
            haz clic en el botón de <strong>Detalles</strong> <i class="bi bi-eye text-primary"></i> de cada equipo.
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Inventario de Hardware</h1>
    <button class="btn btn-primary" @onclick="CrearNuevo">
        <i class="bi bi-pc-display"></i> Nuevo Equipo
    </button>
</div>

@* Barra de búsqueda *@
<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white">Buscar</span>
            <input type="text" class="form-control" placeholder="Buscar por código, marca o responsable..."
                   @bind="textoBusqueda" @bind:event="oninput" />
        </div>
    </div>
</div>

@if (equipos == null)
{
    <p><em>Cargando inventario...</em></p>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Tipo</th>
                    <th>Marca/Modelo</th>
                    <th>Estado</th>
                    <th>Asignado a</th>
                    <th>Ubicación</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var equipo in EquiposPaginados)
                {
                    <tr>
                        <td class="fw-bold">@equipo.codigo_inventario</td>
                        <td>@equipo.tipo_equipo</td>
                        <td>@equipo.marca @equipo.modelo</td>
                        <td>
                            <span class="badge @(equipo.estado == "Activo" ? "bg-success" : "bg-warning text-dark")">
                                @equipo.estado
                            </span>
                        </td>
                        <td>@(equipo.Usuario?.nombre ?? "Sin asignar")</td>
                        <td>@(equipo.Ubicacion?.nombre_area ?? "N/A")</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-info" @onclick="() => VerDetalles(equipo.id_equipo)" title="Ver Detalles">
                                    Ver Detalle
                                </button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => Editar(equipo.id_equipo)" title="Editar">
                                    Editar
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(equipo.id_equipo)" title="Eliminar">
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Paginación *@
    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="text-muted">Página @paginaActual de @totalPaginas (@equiposFiltrados.Count equipos encontrados)</span>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)">Anterior</button>
                </li>
                @for (int i = 1; i <= totalPaginas; i++)
                {
                    int j = i;
                    <li class="page-item @(paginaActual == j ? "active" : "")">
                        <button class="page-link" @onclick="() => CambiarPagina(j)">@j</button>
                    </li>
                }
                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)">Siguiente</button>
                </li>
            </ul>
        </nav>
    </div>
}

@code {
    private List<Equipo>? equipos;
    private List<Equipo> equiposFiltrados = new();
    private string _textoBusqueda = "";

    private string textoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                paginaActual = 1;
                FiltrarEquipos();
            }
        }
    }

    private int paginaActual = 1;
    private int elementosPorPagina = 10;

    protected override async Task OnInitializedAsync()
    {
        equipos = await EquipoService.ObtenerEquipos();
        equiposFiltrados = equipos ?? new();
    }

    private void FiltrarEquipos()
    {
        if (equipos == null) return;

        if (string.IsNullOrWhiteSpace(_textoBusqueda))
        {
            equiposFiltrados = equipos;
        }
        else
        {
            equiposFiltrados = equipos.Where(e =>
                (e.codigo_inventario?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.marca?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.modelo?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.Usuario?.nombre?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private IEnumerable<Equipo> EquiposPaginados =>
        equiposFiltrados
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int totalPaginas => Math.Max(1, (int)Math.Ceiling((double)equiposFiltrados.Count / elementosPorPagina));

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void VerDetalles(int id) => NavigationManager.NavigateTo($"/equipos/detalles/{id}");
    private void CrearNuevo() => NavigationManager.NavigateTo("/equipos/nuevo");
    private void Editar(int id) => NavigationManager.NavigateTo($"/equipos/editar/{id}");

    private async Task Eliminar(int id)
    {
        if (await EquipoService.EliminarEquipo(id))
        {
            equipos = await EquipoService.ObtenerEquipos();
            FiltrarEquipos();
        }
    }
}



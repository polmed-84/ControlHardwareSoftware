@page "/"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IEquipoService EquipoService
@inject IUsuarioService UsuarioService
@inject ILicenciaService LicenciaService
@inject IMantenimientoService MantenimientoService
@rendermode InteractiveServer

<PageTitle>Dashboard - Control Hardware & Software</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-speedometer2"></i> Panel de Control</h1>
        <span class="text-muted">@DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy")</span>
    </div>

    @* Fichas de Resumen Estadístico *@
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm h-100 border-0">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-pc-display"></i></div>
                    <div>
                        <h6 class="card-title mb-0">Total Equipos</h6>
                        <h2 class="mb-0 fw-bold">@totalEquipos</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm h-100 border-0">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-people"></i></div>
                    <div>
                        <h6 class="card-title mb-0">Usuarios</h6>
                        <h2 class="mb-0 fw-bold">@totalUsuarios</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow-sm h-100 border-0">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-key"></i></div>
                    <div>
                        <h6 class="card-title mb-0">Licencias</h6>
                        <h2 class="mb-0 fw-bold">@totalLicencias</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow-sm h-100 border-0">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-tools"></i></div>
                    <div>
                        <h6 class="card-title mb-0">Gastos Soporte</h6>
                        <h2 class="mb-0 fw-bold">$@totalGastos.ToString("N0")</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Sección de Créditos *@
    <div class="row mt-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm bg-light p-5 text-center">
                <div class="mb-3">
                    <svg xmlns="http://w3.org" width="48" height="48" fill="currentColor" class="bi bi-mortarboard text-secondary" viewBox="0 0 16 16">
                        <path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917zM8 8.46 1.758 5.965 8 3.052l6.242 2.913z" />
                        <path d="M4.176 9.032a.5.5 0 0 0-.656.327l-.5 1.7a.5.5 0 0 0 .294.605l4.5 1.8a.5.5 0 0 0 .372 0l4.5-1.8a.5.5 0 0 0 .294-.605l-.5-1.7a.5.5 0 0 0-.656-.327L8 10.466zm-.068 1.873.22-.748 3.496 1.311a.5.5 0 0 0 .352 0l3.496-1.311.22.748L8 12.46z" />
                    </svg>
                </div>
                <h4 class="fw-bold mb-4">SISTEMA DE CONTROL HARDWARE & SOFTWARE</h4>
                <p class="text-uppercase fw-bold text-primary mb-3" style="letter-spacing: 2px;">ELABORADO POR:</p>

                <ul class="list-unstyled fs-5">
                    <li class="mb-2">Eliazar Salomón Polanco Medina</li>
                    <li class="mb-2">Evert Isaí Amador Martínez</li>
                    <li class="mb-2">Isaac David Ramirez Zamora</li>
                </ul>

                <div class="mt-4 text-muted small">
                    © 2026 - Proyecto de Ingeniería de Sistemas
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalEquipos = 0;
    private int totalUsuarios = 0;
    private int totalLicencias = 0;
    private decimal totalGastos = 0;

    protected override async Task OnInitializedAsync()
    {
        var equipos = await EquipoService.ObtenerEquipos();
        totalEquipos = equipos.Count;

        var usuarios = await UsuarioService.ObtenerUsuarios();
        totalUsuarios = usuarios.Count;

        var licencias = await LicenciaService.ObtenerLicencias();
        totalLicencias = licencias.Count;

        var mantenimientos = await MantenimientoService.ObtenerTodos();
        totalGastos = mantenimientos.Sum(m => m.costo ?? 0);
    }
}

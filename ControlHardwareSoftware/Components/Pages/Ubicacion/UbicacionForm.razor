@page "/ubicaciones/nuevo"
@page "/ubicaciones/editar/{Id:int}"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IUbicacionService UbicacionService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@titulo Ubicación</PageTitle>

<h3>@titulo Ubicación</h3>

<div class="card p-4 shadow-sm" style="max-width: 600px;">
    <EditForm Model="ubicacion" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Nombre del Área</label>
            <InputText @bind-Value="ubicacion.nombre_area" class="form-control" placeholder="Ej: Sala de Servidores" />
        </div>

        <div class="mb-3">
            <label class="form-label">Dirección / Piso</label>
            <InputText @bind-Value="ubicacion.direccion" class="form-control" placeholder="Ej: Piso 2, Ala Norte" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <InputTextArea @bind-Value="ubicacion.descripcion" class="form-control" rows="3" />
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success">Guardar</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private Ubicacion ubicacion = new();
    private string titulo = "Nueva";

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            var uDb = await UbicacionService.ObtenerUbicacionPorId(Id.Value);
            if (uDb != null)
            {
                ubicacion = uDb;
                titulo = "Editar";
            }
        }
    }

    private async Task Guardar()
    {
        await UbicacionService.GuardarUbicacion(ubicacion);
        NavigationManager.NavigateTo("/ubicaciones");
    }

    private void Cancelar() => NavigationManager.NavigateTo("/ubicaciones");
}

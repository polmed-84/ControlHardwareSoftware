@page "/reportes/mantenimientos"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject IMantenimientoService MantenimientoService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Reporte de Gastos</PageTitle>

@* Botón de impresión oculto al imprimir *@
<div class="d-flex justify-content-end mb-3 d-print-none">
    <button class="btn btn-primary" @onclick="Imprimir">
        <svg xmlns="http://w3.org" width="16" height="16" fill="currentColor" class="bi bi-printer-fill me-2" viewBox="0 0 16 16">
            <path d="M5 1a2 2 0 0 0-2 2v1h10V3a2 2 0 0 0-2-2zm6 8H5a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1" />
            <path d="M0 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-1v-2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2H2a2 2 0 0 1-2-2zm2.5 1a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1" />
        </svg> Generar PDF / Imprimir
    </button>
</div>

<div class="card shadow p-4 border-0">
    <div class="text-center mb-4">
        <h2 class="fw-bold text-uppercase">Historial de Mantenimientos y Gastos</h2>
        <p class="text-muted">Reporte generado el @DateTime.Now.ToLongDateString()</p>
    </div>

    @* Tarjetas de Resumen *@
    <div class="row mb-4">
        <div class="col-6 col-md-4">
            <div class="p-3 border rounded bg-light text-center shadow-sm">
                <h6 class="text-muted text-uppercase small">Gasto Total Acumulado</h6>
                <h3 class="text-danger fw-bold">$@listaMant?.Sum(m => m.costo ?? 0).ToString("N2")</h3>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="p-3 border rounded bg-light text-center shadow-sm">
                <h6 class="text-muted text-uppercase small">Total Servicios</h6>
                <h3 class="fw-bold">@listaMant?.Count</h3>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Equipo (Código)</th>
                    <th>Tipo de Servicio</th>
                    <th>Técnico</th>
                    <th class="text-end">Costo</th>
                </tr>
            </thead>
            <tbody>
                @if (listaMant != null && listaMant.Any())
                {
                    @foreach (var m in listaMant.OrderByDescending(x => x.fecha_mantenimiento))
                    {
                        <tr>
                            <td>@m.fecha_mantenimiento?.ToShortDateString()</td>
                            <td class="fw-bold">@m.Equipo?.codigo_inventario</td>
                            <td>@m.tipo_mantenimiento</td>
                            <td>@m.tecnico</td>
                            <td class="text-end">$@m.costo?.ToString("N2")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center p-4 text-muted">No se encontraron registros de mantenimiento.</td>
                    </tr>
                }
            </tbody>
            @if (listaMant != null && listaMant.Any())
            {
                <tfoot>
                    <tr class="table-secondary fw-bold">
                        <td colspan="4" class="text-end text-uppercase">Gran Total:</td>
                        <td class="text-end">$@listaMant.Sum(m => m.costo ?? 0).ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@code {
    private List<Mantenimiento>? listaMant;

    protected override async Task OnInitializedAsync()
    {
        listaMant = await MantenimientoService.ObtenerTodos();
    }

    private async Task Imprimir()
    {
        await JS.InvokeVoidAsync("imprimirReporte");
    }
}

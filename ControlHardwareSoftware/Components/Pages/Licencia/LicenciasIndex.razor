@page "/licencias"
@using ControlHardwareSoftware.Components.Models
@using ControlHardwareSoftware.Components.Services
@inject ILicenciaService LicenciaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Gestión de Licencias</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Licencias de Software</h1>
    <button class="btn btn-primary" @onclick="CrearNuevo">
        <i class="bi bi-key"></i> Nueva Licencia
    </button>
</div>

@* Barra de búsqueda *@
<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white">Buscar</span>
            <input type="text" class="form-control" placeholder="Buscar por software, tipo o proveedor..."
                   @bind="textoBusqueda" @bind:event="oninput" />
        </div>
    </div>
</div>

@if (licencias == null)
{
    <p><em>Cargando licencias...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover shadow-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Software</th>
                    <th>Tipo</th>
                    <th>Clave / Serial</th>
                    <th>Cantidad</th>
                    <th>Vencimiento</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in LicenciasPaginadas)
                {
                    <tr>
                        <td><strong>@l.Software?.nombre</strong></td>
                        <td>@l.tipo_licencia</td>
                        <td><code>@l.clave_licencia</code></td>
                        <td class="text-center">@l.cantidad_licencias</td>
                        <td>@l.fecha_vencimiento?.ToShortDateString()</td>
                        <td>
                            <span class="badge @(l.estado == "Activa" ? "bg-success" : "bg-danger")">
                                @l.estado
                            </span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => Editar(l.id_licencia)" title="Editar">
                                Editar
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(l.id_licencia)" title="Eliminar">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Controles de Paginación *@
    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="text-muted">Página @paginaActual de @totalPaginas (@licenciasFiltradas.Count registros)</span>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)">Anterior</button>
                </li>
                @for (int i = 1; i <= totalPaginas; i++)
                {
                    int j = i;
                    <li class="page-item @(paginaActual == j ? "active" : "")">
                        <button class="page-link" @onclick="() => CambiarPagina(j)">@j</button>
                    </li>
                }
                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)">Siguiente</button>
                </li>
            </ul>
        </nav>
    </div>
}

@code {
    private List<Licencia>? licencias;
    private List<Licencia> licenciasFiltradas = new();
    private string _textoBusqueda = "";

    private string textoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                paginaActual = 1;
                FiltrarLicencias();
            }
        }
    }

    private int paginaActual = 1;
    private int elementosPorPagina = 8;

    protected override async Task OnInitializedAsync()
    {
        licencias = await LicenciaService.ObtenerLicencias();
        licenciasFiltradas = licencias ?? new();
    }

    private void FiltrarLicencias()
    {
        if (licencias == null) return;

        if (string.IsNullOrWhiteSpace(_textoBusqueda))
        {
            licenciasFiltradas = licencias;
        }
        else
        {
            licenciasFiltradas = licencias.Where(l =>
                (l.Software?.nombre?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (l.tipo_licencia?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (l.proveedor?.Contains(_textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private IEnumerable<Licencia> LicenciasPaginadas =>
        licenciasFiltradas
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int totalPaginas => Math.Max(1, (int)Math.Ceiling((double)licenciasFiltradas.Count / elementosPorPagina));

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void CrearNuevo() => NavigationManager.NavigateTo("/licencias/nuevo");
    private void Editar(int id) => NavigationManager.NavigateTo($"/licencias/editar/{id}");

    private async Task Eliminar(int id)
    {
        await LicenciaService.EliminarLicencia(id);
        licencias = await LicenciaService.ObtenerLicencias();
        FiltrarLicencias();
    }
}
